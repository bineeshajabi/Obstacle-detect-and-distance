<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:macro name="agv_joints_state_publisher">    
  	<gazebo>
         <plugin filename="gz-sim-joint-state-publisher-system"
         name="gz::sim::systems::JointStatePublisher">
         <topic>joint_states</topic>
         <joint_name>wheel_right_base</joint_name>
         <joint_name>wheel_left_base</joint_name>
         <joint_name>caster_front_left_joint</joint_name>
         <joint_name>caster_front_right_joint</joint_name>
         <joint_name>caster_back_right_joint</joint_name>
         <joint_name>caster_back_left_joint</joint_name>
         <joint_name>caster_front_left_wheel_joint</joint_name>
         <joint_name>caster_front_right_wheel_joint</joint_name>
         <joint_name>caster_back_left_wheel_joint</joint_name>
         <joint_name>caster_back_right_wheel_joint</joint_name>
         <updateRate>10.0</updateRate>
      </plugin>
    </gazebo>
  </xacro:macro>

  <xacro:macro name="agv_diff_drive">
    <gazebo>
       <plugin
         filename="gz-sim-diff-drive-system"
         name="gz::sim::systems::DiffDrive">
         <left_joint>wheel_right_base</left_joint>
         <right_joint>wheel_left_base</right_joint>
         <wheel_separation>0.60</wheel_separation>
         <wheel_radius>0.10</wheel_radius>
         <topic>cmd_vel</topic>
         <maximum_linear_acceleration>2</maximum_linear_acceleration>
         <max_velocity>5</max_velocity>
         <!-- <min_velocity>0</min_velocity> -->
         <odom_topic>odom</odom_topic>
         <frame_id>odom</frame_id>
         <odom_publisher_frequency>30</odom_publisher_frequency>
         <child_frame_id>base_link</child_frame_id>
         <tf_topic>/tf</tf_topic>
         <wheelTorque>20</wheelTorque>
        <wheelAcceleration>1.8</wheelAcceleration> 
        <updateRate>150.0</updateRate>
      </plugin>
    </gazebo>

  </xacro:macro>

  <xacro:macro name="agv_imu">
  <gazebo reference = "imu_link">
    <sensor name="imu" type="imu">
    <always_on>true</always_on>
    <update_rate>200</update_rate>
    <gz_frame_id>imu_link</gz_frame_id>
    <topic>imu</topic>
    <imu>
     <angular_velocity>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>2e-4</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.7e-2</stddev>
              </noise>
            </x>
            <y>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.7e-2</stddev>
              </noise>
            </y>
            <z>
              <noise type="gaussian">
                <mean>0.0</mean>
                <stddev>1.7e-2</stddev>
              </noise>
            </z>
          </linear_acceleration>
    </imu>
  </sensor>
  </gazebo>

  </xacro:macro>
</robot>